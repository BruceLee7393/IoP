# Flask runtime settings
FLASK_CONFIG=dev
FLASK_APP=backend:create_app
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
AUTO_DB_BOOTSTRAP=1
SECRET_KEY=iop-dev-secret-key
JWT_SECRET_KEY=iop-dev-jwt-secret

# Core database connection (preferred)
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:1234@127.0.0.1:3306/IoP

# Optional compatibility fields (used if SQLALCHEMY_DATABASE_URI is absent)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=IoP

# Redis settings
REDIS_URL=redis://127.0.0.1:6379/0
